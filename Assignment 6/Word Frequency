import re
text=input("Enter your text or whatever ")
words= re.findall(r'\b\w+\b',text.lower())
numoword=len(words)
frequency ={}
for word in words:
    if word in frequency:
        frequency[word]+=1
    else:
        frequency[word]=1
sorted_fre=sorted(frequency.items(),key=lambda x: x[1], reverse=True)[:5]
sumhigh=sum(e[1] for e in sorted_fre)
propotion=(sumhigh)/(numoword)*100
print("\nMost frequent words:")
for word, count in sorted_fre:
    print(f"{word} :{count}")
print(f"total number of word :{numoword}")
print(f"propotion of 5 highest number of word to all of the word is : {propotion} %")